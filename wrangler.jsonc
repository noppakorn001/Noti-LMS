{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "noti-lms",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "NOTI_LMS_KV",
      "id": "NOTI_LMS_KV_PLACEHOLDER"
    }
  ],
  "observability": {
    "enabled": true
  }
}
